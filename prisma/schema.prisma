datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

model Course {
  id          String   @id @default(uuid())
  slug        String?  @unique
  title       String
  description String
  majorId     String   @default("")
  modules     Module[]
}

model Module {
  id               String  @id @default(uuid())
  title            String
  pdfUrl           String?
  videoUrl         String?
  aiContextSummary String? @default("")
  transcript       String? @default("")
  courseId         String
  course           Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
}
